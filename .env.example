# Зайди на https://my.telegram.org:
# 1. Введи свой номер телефона TELEGRAM_PHONE=+7XXXXXXXXXX
TELEGRAM_PHONE=
# 2. Получишь код подтверждения в Telegram (не SMS)
# 3. Войди → выбери "API development tools"
# 4. Заполни форму (App title и Short name — любые, например multi-claw)
# 5. Нажми "Create application"
# На странице появятся твои App api_id и App api_hash — вставь их в .env.
# Telegram User API (for group creation script)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Telegram user ID — кому разрешён доступ ко всем ботам (get from @userinfobot)
TELEGRAM_ALLOW_FROM=

# Google Calendar (shared across all pods)
GOOGLE_CALENDAR_ID=your-calendar@group.calendar.google.com
# Service account JSON file: place your key at credentials/service-account.json
CALENDAR_TIMEZONE=Asia/Jerusalem

# 12 Telegram Bot Tokens (create via @BotFather)
TELEGRAM_TOKEN_MINI_CLAW=
TELEGRAM_TOKEN_PICO_CLAW=
TELEGRAM_TOKEN_NANO_CLAW=
TELEGRAM_TOKEN_TINY_CLAW=
TELEGRAM_TOKEN_OPEN_CLAW=
TELEGRAM_TOKEN_ZERO_CLAW=
TELEGRAM_TOKEN_TITAN_CLAW=
TELEGRAM_TOKEN_KAF_CLAW=
TELEGRAM_TOKEN_SAFE_CLAW=
TELEGRAM_TOKEN_NULL_CLAW=
TELEGRAM_TOKEN_TINYAGI=
TELEGRAM_TOKEN_NANOBOT=

# AI API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# Docker Compose profiles (auto-synced by: python run.py compose)
# Determines which pods start with: docker compose up -d --build
COMPOSE_PROFILES=mini-claw,pico-claw
